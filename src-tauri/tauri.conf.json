{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AniVault",
  "version": "0.1.0",
  "identifier": "com.anivault.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node scripts/download-node.cjs && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AniVault",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../csp-engine": "csp-engine",
      "resources/node": "node"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}